{
  "datasets": [
    {
      "name": "chronic_risk_countries",
      "displayName": "Chronic Risk Countries",
      "queryLines": [
        "SELECT\n",
        "  country,\n",
        "  COUNT(*) as total_years_tracked,\n",
        "  SUM(\n",
        "    CASE\n",
        "      WHEN social_risk_level = 'High Risk' THEN 1\n",
        "      ELSE 0\n",
        "    END\n",
        "  ) as years_in_high_risk,\n",
        "  ROUND(\n",
        "    100.0\n",
        "      * SUM(\n",
        "        CASE\n",
        "          WHEN social_risk_level = 'High Risk' THEN 1\n",
        "          ELSE 0\n",
        "        END\n",
        "      )\n",
        "      / COUNT(*),\n",
        "    1\n",
        "  ) as pct_years_high_risk,\n",
        "  ROUND(AVG(social_risk_score), 3) as avg_social_risk_score,\n",
        "  ROUND(MAX(social_risk_score), 3) as peak_risk_score,\n",
        "  MAX(\n",
        "    CASE\n",
        "      WHEN social_risk_level = 'High Risk' THEN year\n",
        "    END\n",
        "  ) as most_recent_high_risk_year,\n",
        "  CASE\n",
        "    WHEN AVG(social_risk_score) > 0.6 THEN '🔴 Chronic High Risk'\n",
        "    WHEN\n",
        "      SUM(\n",
        "        CASE\n",
        "          WHEN social_risk_level = 'High Risk' THEN 1\n",
        "          ELSE 0\n",
        "        END\n",
        "      ) >= 3\n",
        "    THEN\n",
        "      '🟡 Recurring High Risk'\n",
        "    ELSE '🟢 Stable'\n",
        "  END as attention_priority\n",
        "FROM\n",
        "  workspace.default.social_risk_dashboard\n",
        "GROUP BY\n",
        "  country\n",
        "ORDER BY\n",
        "  avg_social_risk_score DESC"
      ]
    },
    {
      "name": "current_risk_snapshot",
      "displayName": "Current Risk Snapshot",
      "queryLines": [
        "SELECT\n",
        "  country,\n",
        "  year,\n",
        "  ROUND(social_risk_score, 3) as social_risk_score,\n",
        "  social_risk_level,\n",
        "  ROUND(gini_risk_score, 2) as gini_risk,\n",
        "  ROUND(poverty_risk_score, 2) as poverty_risk,\n",
        "  ROUND(mortality_risk_score, 2) as mortality_risk\n",
        "FROM\n",
        "  workspace.default.social_risk_dashboard\n",
        "WHERE\n",
        "  year\n",
        "    = (\n",
        "      SELECT\n",
        "        MAX(year)\n",
        "      FROM\n",
        "        workspace.default.social_risk_dashboard\n",
        "    )\n",
        "ORDER BY\n",
        "  social_risk_score DESC"
      ]
    },
    {
      "name": "risk_trend_5yr",
      "displayName": "5-Year Risk Trend",
      "queryLines": [
        "WITH recent_years AS (\n",
        "  SELECT DISTINCT\n",
        "    year\n",
        "  FROM\n",
        "    workspace.default.social_risk_dashboard\n",
        "  ORDER BY\n",
        "    year DESC\n",
        "  LIMIT 5\n",
        ")\n",
        "SELECT\n",
        "  country,\n",
        "  year,\n",
        "  ROUND(social_risk_score, 3) as social_risk_score,\n",
        "  social_risk_level\n",
        "FROM\n",
        "  workspace.default.social_risk_dashboard\n",
        "WHERE\n",
        "  year IN (\n",
        "    SELECT\n",
        "      year\n",
        "    FROM\n",
        "      recent_years\n",
        "  )\n",
        "ORDER BY\n",
        "  country,\n",
        "  year"
      ]
    }
  ],
